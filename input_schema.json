{
  "title": "Input Schema",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "startUrls": {
      "title": "Start URLs",
      "type": "array",
      "description": "List of Apec job search URLs to scrape.",
      "editor": "requestListSources",
      "prefill": [
        { "url": "https://www.apec.fr/candidat/recherche-emploi.html/emploi?motsCles=engineer" }
      ]
    },
    "maxItems": {
      "title": "Max Items",
      "type": "integer",
      "description": "Maximum number of items to scrape.",
      "default": 100
    },
    "proxyConfig": {
      "title": "Proxy Configuration",
      "type": "object",
      "editor": "proxy",
      "description": "Proxy configuration.",
      "default": {
        "useApifyProxy": true
      }
    }
  },
  "required": [
    "startUrls"
  ]
}