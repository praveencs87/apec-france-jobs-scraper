{
  "title": "Input Schema",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "searchQueries": {
      "title": "Search Queries",
      "type": "array",
      "description": "List of keywords to search for.",
      "editor": "stringList",
      "default": [
        "engineer"
      ],
      "prefill": [
        "engineer"
      ]
    },
    "maxItems": {
      "title": "Max Items",
      "type": "integer",
      "description": "Maximum number of items to scrape.",
      "default": 100
    },
    "proxyConfig": {
      "title": "Proxy Configuration",
      "type": "object",
      "editor": "proxy",
      "description": "Proxy configuration.",
      "default": {
        "useApifyProxy": true
      }
    }
  }
}